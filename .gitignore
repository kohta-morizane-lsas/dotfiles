# Machine-local overrides (*.example files are tracked as templates)
*.local
*.local.*
!*.local.example
!*.local.*.example

# Secrets
.env
.env.*
credentials*
*.key
*.pem
id_rsa*
id_ed25519*
known_hosts

# Claude Code project-local state (Claude Code itself is not managed by dotfiles)
.claude/

# macOS
.DS_Store

# Vim swap
*.swp
*.swo

# Node
node_modules/

# Python
__pycache__/
*.pyc
