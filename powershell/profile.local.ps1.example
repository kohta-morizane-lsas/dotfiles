#   Set-Location "\\wsl.localhost\Ubuntu\home\YOUR_WSL_USER"
# }

# --- PowerToys CommandNotFound module (requires PowerToys) ---
# Import-Module -Name Microsoft.WinGet.CommandNotFound -ErrorAction SilentlyContinue

# --- Machine-specific tool aliases ---
# . "$env:USERPROFILE\tools\powershell-profile\tools-aliases.ps1"
