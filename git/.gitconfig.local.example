# Machine-local git config — copy to ~/.gitconfig.local and fill in values.
# This file is NOT tracked by git (*.local is gitignored).

[user]
    name = Your Name
    email = you@example.com

# gh must be on PATH (resolved at runtime — works on both WSL and Windows)
[credential "https://github.com"]
    helper =
    helper = !gh auth git-credential

[credential "https://gist.github.com"]
    helper =
    helper = !gh auth git-credential
