# Machine-local bash overrides — copy to ~/.bashrc.local and customise.
# This file is NOT tracked by git (*.local is gitignored).

# --- WSL-specific tools PATH ---
# export PATH="$HOME/tools/git-worktree/:$PATH"
# export PATH="$HOME/tools/serena-setup/:$PATH"
# alias worktree="worktree.sh"

# --- .NET ---
